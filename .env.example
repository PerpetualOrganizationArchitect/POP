# POA Protocol Deployment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══════════════════════════ REQUIRED ═══════════════════════════

# Private key for deployment (DO NOT COMMIT .env!)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ═══════════════════════════ CROSS-CHAIN DEPLOYMENT ═══════════════════════════

# Hyperlane mailbox address (chain-specific)
MAILBOX=

# Hyperlane domain IDs: Ethereum=1, Arbitrum=42161, Optimism=10, Gnosis=100
HUB_DOMAIN=
SATELLITE_DOMAIN=

# For RegisterAndTransfer (Step 3)
NUM_SATELLITES=
SATELLITE_DOMAIN_0=
SATELLITE_DOMAIN_1=

# ═══════════════════════════ OPTIONAL ═══════════════════════════

# Etherscan API key for contract verification (optional)
# Get your key at: https://etherscan.io/myapikey
# Add --verify --etherscan-api-key $ETHERSCAN_API_KEY to deployment commands
ETHERSCAN_API_KEY=

# IPFS metadata for governance org
ORG_METADATA_HASH=
MEMBER_ROLE_IMAGE=
MEMBER_ROLE_METADATA=
CONTRIBUTOR_ROLE_IMAGE=
CONTRIBUTOR_ROLE_METADATA=
