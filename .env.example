# POA Protocol Deployment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══════════════════════════ REQUIRED ═══════════════════════════

# Private key for deployment (DO NOT COMMIT .env!)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ═══════════════════════════ CROSS-CHAIN DEPLOYMENT ═══════════════════════════
# Home chain: Arbitrum
# Satellites: Ethereum, Optimism, Gnosis

# Hyperlane mailbox addresses (chain-specific, set per step)
#   Arbitrum:  0x979Ca5202784112f4738403dBec5D0F3B9daabB9
#   Ethereum:  0xc005dc82818d67AF737725bD4bf75435d065D239
#   Optimism:  0xd4C1905BB1D26BC93DAC913e13CaCC278CdCC80D
#   Gnosis:    0xaD09d78f4c6b9dA2Ae82b1D34107802d380Bb74f

# Step 1: DeployHomeChain (run on Arbitrum)
MAILBOX=0x979Ca5202784112f4738403dBec5D0F3B9daabB9
HUB_DOMAIN=42161

# Step 2: DeploySatellite (run once per satellite chain, update MAILBOX + SATELLITE_DOMAIN each time)
# Ethereum:  MAILBOX=0xc005dc82818d67AF737725bD4bf75435d065D239  SATELLITE_DOMAIN=1
# Optimism:  MAILBOX=0xd4C1905BB1D26BC93DAC913e13CaCC278CdCC80D  SATELLITE_DOMAIN=10
# Gnosis:    MAILBOX=0xaD09d78f4c6b9dA2Ae82b1D34107802d380Bb74f  SATELLITE_DOMAIN=100
SATELLITE_DOMAIN=

# Step 3: RegisterAndTransfer (run on Arbitrum)
NUM_SATELLITES=3
SATELLITE_DOMAIN_0=1
SATELLITE_DOMAIN_1=10
SATELLITE_DOMAIN_2=100

# ═══════════════════════════ OPTIONAL ═══════════════════════════

# Etherscan API key for contract verification (optional)
# Get your key at: https://etherscan.io/myapikey
# Add --verify --etherscan-api-key $ETHERSCAN_API_KEY to deployment commands
ETHERSCAN_API_KEY=

# IPFS metadata for governance org
ORG_METADATA_HASH=
MEMBER_ROLE_IMAGE=
MEMBER_ROLE_METADATA=
CONTRIBUTOR_ROLE_IMAGE=
CONTRIBUTOR_ROLE_METADATA=
